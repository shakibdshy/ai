# Environment variables for CLI testing
# Copy this file to .env.local and fill in your API keys

# OpenAI API Key (for live tests with --provider openai)
OPENAI_API_KEY=sk-...

# Anthropic API Key (for live tests with --provider anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API Key (for live tests with --provider gemini)
GEMINI_API_KEY=your-gemini-api-key-here

